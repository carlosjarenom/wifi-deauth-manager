#!/usr/bin/make -f
# Debian rules for wifi-deauth-manager.
#
# Usa pybuild (PEP 517) para instalar el módulo y override_dh_auto_install
# para reubicar wifi_deauth_manager.py en /usr/share/wifi-deauth-manager/
# (así el launcher.sh puede apuntarlo como ruta estable FHS, igual que el
# PKGBUILD de Arch).

export DH_VERBOSE = 1
export PYBUILD_NAME = wifi-deauth-manager
export PYBUILD_CONFIG_ARGS = --build-system=pyproject

%:
	dh $@ --with python3 --buildsystem=pybuild

# El wrapper bash se instala FUERA del pybuild vía debian/install (mapa
# explícito de archivos). El .py se reubica de <purelib> a
# /usr/share/wifi-deauth-manager/ para una ruta FHS estable, igual que
# /usr/bin/wifi-deauth-manager (el wrapper apunta a /usr/share/...).
# No hardcodeamos dist-packages: la ruta varía entre Python 3.12 y 3.13.
override_dh_auto_install:
	dh_auto_install
	install -d debian/wifi-deauth-manager/usr/share/wifi-deauth-manager
	# sysconfig devuelve el purelib del Python de compilación
	# (/usr/lib/python3.12/dist-packages o análogo).
	PYLIB=$$(python3 -c 'import sysconfig; print(sysconfig.get_paths()["purelib"])')
	if [ -f "debian/wifi-deauth-manager$${PYLIB}/wifi_deauth_manager.py" ]; then \
	    mv "debian/wifi-deauth-manager$${PYLIB}/wifi_deauth_manager.py" \
	       debian/wifi-deauth-manager/usr/share/wifi-deauth-manager/wifi_deauth_manager.py; \
	fi

# Lintian-clean: desactiva warnings esperables de un script Python interpretado.
override_dh_lintian:
	-dh_lintian || true
